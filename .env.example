# =============================================================================
# Example environment file.
# Copy to ".env" and fill in real values. NEVER commit the real ".env".
# install.sh generates ".env" interactively with chmod 600.
# =============================================================================

# --- Telegram bot ------------------------------------------------------------
# Bot token from @BotFather.
BOT_TOKEN=123456789:replace-with-bot-token

# Telegram numeric user id of the main (super) admin.
MAIN_ADMIN_ID=123456789

# Optional: numeric id of a Telegram group/channel to receive bot logs.
# Leave empty to disable log forwarding.
LOG_GROUP_ID=

# --- Web admin panel ---------------------------------------------------------
# Public domain the panel is served on (used by nginx + certbot).
WEB_DOMAIN=panel.example.com

# Web panel admin login username.
WEB_ADMIN_USERNAME=admin

# Bcrypt hash of the web admin password (NOT the plaintext password).
# Generate with:
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpass'))"
WEB_ADMIN_PASSWORD_HASH=$2b$12$replace-with-a-real-bcrypt-hash

# --- Database (PostgreSQL) ---------------------------------------------------
# Password for the PostgreSQL "appstore" user (used by docker-compose).
DB_PASSWORD=replace-with-db-password

# Async SQLAlchemy connection URL.
# Docker default points at the "db" service:
DATABASE_URL=postgresql+asyncpg://appstore:replace-with-db-password@db:5432/appstore

# --- Redis -------------------------------------------------------------------
# Async Redis URL (FSM storage, locks, throttling).
REDIS_URL=redis://redis:6379/0

# --- Security ----------------------------------------------------------------
# Secret key for JWT signing / session cookies. install.sh generates a random
# value. Generate manually with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-secret
